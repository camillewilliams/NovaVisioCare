{
  "manifest_version": 3,
  "name": "Nova VisioCare",
  "version": "1.0",
  "description": "Project for CSCI 2356",
  "permissions": ["activeTab"],
  "host_permissions": [
    "<all_urls>",
    "http://mapd.cs-smu.ca:3026/*"
  ],
  "background": {
    "service_worker": "background.js"
  },
  "content_scripts": [
    {
      "matches": ["<all_urls>"],
      "js": ["content.js"]
    }
  ]
}
